# ETH Trading Dashboard — API Keys
# Copy to .env and fill in values. NEVER commit .env to git.

# Required for market data
COINGECKO_API_KEY=
ETHERSCAN_API_KEY=
CRYPTOQUANT_API_KEY=
SOSOVALUE_API_KEY=
CMC_API_KEY=         # CoinMarketCap Free/Basic — F&G index, global metrics, ETH/BTC quotes

# Required for Telegram bot (optional — bot is disabled if blank)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHATS=   # comma-separated chat IDs; leave blank to allow all

# Server config
PORT=5001
DEBUG=false
DASHBOARD_URL=http://localhost:5001

# No key required for these (called directly):
# api.alternative.me/fng/
# ethereumfear.com
# www.reddit.com/r/ethereum.json
# api.llama.fi/
# api.crypto.com/exchange/v1/public/
