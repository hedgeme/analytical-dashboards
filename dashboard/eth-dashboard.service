[Unit]
Description=ETH Trading Dashboard (Flask API + Telegram bot)
Documentation=https://github.com/hedgeme/analytical-dashboards
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=tecviva
Group=tecviva
WorkingDirectory=/home/tecviva/analytical-dashboards/dashboard
EnvironmentFile=/home/tecviva/analytical-dashboards/dashboard/.env
Environment=PYTHONPATH=/home/tecviva/analytical-dashboards/dashboard
Environment=PATH=/home/tecviva/analytical-dashboards/dashboard/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin
ExecStart=/home/tecviva/analytical-dashboards/dashboard/venv/bin/python app.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=eth-dashboard
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
